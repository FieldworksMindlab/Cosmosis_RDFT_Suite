# Copy this to .env and edit as needed.

PYTHON_BIN=python3

# Processing listens for these UDP packets locally.
HOLO_HOST=127.0.0.1
SOLAR_PORT=5060
SOLAR_INTERVAL=120
SOLAR_SIMULATE=0

# Galaxy maps are cached. Set to 1 only when you want a live astronomy refresh.
GALAXY_REFRESH=0
GALAXY_TIMEOUT_SECONDS=20

# Surface/topology sender.
SURFACE_MODE=gyroid
SURFACE_GRID=32
SURFACE_FPS=12

# Real terrain mode. Use SURFACE_MODE=real_topography to start directly on DEM terrain.
# SURFACE_TERRAIN_SOURCE can be opentopodata, opentopography, or fallback.
SURFACE_TERRAIN_SOURCE=opentopodata
SURFACE_TERRAIN_PRESET=grand_canyon
SURFACE_TERRAIN_DEMTYPE=srtm30m
SURFACE_TERRAIN_BATCH_DELAY=1.1

# Optional OpenTopography key. Required only for SURFACE_TERRAIN_SOURCE=opentopography.
OPENTOPO_API_KEY=

# Open GUI/audio apps after the sender package starts.
HOLO_OPEN_PROCESSING=1
HOLO_OPEN_SUPERCOLLIDER=1

# App names on macOS. Change these if your installed names differ.
PROCESSING_APP=Processing
SUPERCOLLIDER_APP=SuperCollider
